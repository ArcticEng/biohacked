# ═══════════════════════════════════════════════════
# BIO-HACKED Environment Configuration
# ═══════════════════════════════════════════════════

# ─── Database (PostgreSQL via Supabase) ────────────
# Dev: local postgres is fine
# Prod: use Supabase "Session pooler" URL for DATABASE_URL
#       and "Direct connection" URL for DIRECT_DATABASE_URL
DATABASE_URL="postgresql://user:password@localhost:5432/biohacked?schema=public"
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/biohacked?schema=public"

# ─── Auth ──────────────────────────────────────────
JWT_SECRET="change-me-generate-with-openssl-rand-hex-32"
JWT_EXPIRES_IN="7d"

# ─── Anthropic (AI Recipe & Meal Plan Generation) ──
ANTHROPIC_API_KEY="sk-ant-api03-your-key-here"

# ─── PayFast (ZAR subscriptions) ───────────────────
PAYFAST_MERCHANT_ID="your-merchant-id"
PAYFAST_MERCHANT_KEY="your-merchant-key"
PAYFAST_PASSPHRASE="your-passphrase"
PAYFAST_MODE="sandbox"  # sandbox | live

# ─── App ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Bio-Hacked"

# ─── File Storage ──────────────────────────────────
# STORAGE_PROVIDER: "local" (dev) or "supabase" (prod)
STORAGE_PROVIDER="local"
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."   # service_role, NOT anon key
SUPABASE_BUCKET="uploads"
